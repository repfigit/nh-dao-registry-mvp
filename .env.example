# --- Registry identity ---
# The hostname this registry serves at. did:web identifiers are derived from
# this. For the demo, you can run on localhost; for production, set to the
# real SoS-controlled host (e.g. nhdaoregistry.nh.gov).
REGISTRY_HOST=localhost:3000
# Use http for local dev, https for production. did:web spec assumes https
# in production; localhost is the documented exception.
REGISTRY_SCHEME=http

# Server port
PORT=3000

# --- Polygon Amoy testnet ---
# RPC endpoint. Public options: https://rpc-amoy.polygon.technology
# Or use Alchemy/Infura for production reliability.
AMOY_RPC_URL=https://rpc-amoy.polygon.technology

# Funded testnet account that will sign anchor transactions.
# Get free test MATIC at https://faucet.polygon.technology/
# DO NOT REUSE A MAINNET KEY HERE. Generate a fresh one.
ANCHOR_PRIVATE_KEY=0x

# Address of the deployed DAORegistryAnchor contract.
# Filled in after `npm run deploy:amoy`.
ANCHOR_CONTRACT_ADDRESS=

# --- IPFS pinning (web3.storage) ---
# Optional. If unset, the registry will compute a real CIDv1 from the
# document bytes but will not actually pin to public IPFS. This is fine for
# local development; set both for real public pinning.
#
# Sign up at https://console.web3.storage, create a Space, then run:
#   npx w3 login your@email
#   npx w3 space create
#   npx w3 space use <DID>
#   npx w3 delegation create <agent-did> --output delegation.car
# Then paste the agent DID and base64-encoded delegation here.
W3UP_AGENT_KEY=
W3UP_DELEGATION_PROOF=

# --- Registry controller key ---
# Ed25519 keypair the registry uses to sign DID documents.
# Two ways to supply it (in order of precedence):
#
#   1. CONTROLLER_PRIVATE_KEY: a 64-char hex (32-byte Ed25519 seed). Pull
#      this from a secrets manager / KMS in production. Preferred — the key
#      never touches disk.
#   2. CONTROLLER_KEY_PATH: path to a JSON keyfile (created automatically
#      on first run if neither is set). Convenient for local dev.
#
# CONTROLLER_PRIVATE_KEY=
CONTROLLER_KEY_PATH=data/keys/controller.json

# --- Filing endpoint authentication ---
# If set, POST /api/file requires Authorization: Bearer <key>. Leave unset
# to keep the endpoint open (reference-impl default; production must set it
# before exposing the server).
# FILING_API_KEY=

# --- Rate limits ---
# Token-bucket rate limits per client IP. Reasonable defaults for the POC;
# tune for your deployment.
# FILING_RATE_WINDOW_MS=60000
# FILING_RATE_MAX=10
# VERIFY_RATE_WINDOW_MS=60000
# VERIFY_RATE_MAX=60

# --- Limits ---
# Maximum body size accepted by Express (passed to express.json).
# REQUEST_BODY_LIMIT=5mb
# Maximum size in bytes of governance bytes pinned to IPFS per filing.
# MAX_GOVERNANCE_BYTES=5242880

# --- Anchor retry policy ---
# ANCHOR_MAX_RETRIES=3
# ANCHOR_BASE_DELAY_MS=500
